# =============================================================================
# Kubernetes Learning Cluster — Vagrant + VirtualBox
# =============================================================================
# Cluster: 1 Control-Plane (master) + 2 Workers
# OS:      Ubuntu 22.04 LTS (jammy)
# CNI:     Flannel (pod network: 10.244.0.0/16)
# CRI:     containerd
#
# Usage:
#   vagrant up            — create + provision all 3 nodes
#   vagrant halt          — stop all nodes (VMs saved)
#   vagrant up            — start them again (no re-provisioning)
#   vagrant destroy -f    — delete all VMs completely
#   vagrant ssh master    — SSH into master node
#   vagrant ssh worker1   — SSH into worker1
#   vagrant status        — see state of all nodes
#
# After `vagrant up`, kubectl is configured on master:
#   vagrant ssh master
#   kubectl get nodes
# =============================================================================

NUM_WORKERS    = 2
MASTER_IP      = "192.168.56.10"
WORKER_IP_BASE = "192.168.56."
WORKER_IP_START = 11
POD_CIDR       = "10.244.0.0/16"

Vagrant.configure("2") do |config|

  # ── Base box ────────────────────────────────────────────────────────────────
  config.vm.box               = "ubuntu/jammy64"   # Ubuntu 22.04 LTS
  config.vm.box_check_update  = false

  # ── Common provisioner (runs on ALL nodes) ──────────────────────────────────
  config.vm.provision "shell", path: "scripts/common.sh"

  # ── MASTER node ─────────────────────────────────────────────────────────────
  config.vm.define "master" do |master|
    master.vm.hostname = "master"
    master.vm.network "private_network", ip: MASTER_IP

    master.vm.provider "virtualbox" do |vb|
      vb.name   = "k8s-master"
      vb.cpus   = 2
      vb.memory = 2048
      vb.customize ["modifyvm", :id, "--natdnshostresolver1", "on"]
    end

    master.vm.provision "shell",
      path: "scripts/master.sh",
      env: {
        "MASTER_IP" => MASTER_IP,
        "POD_CIDR"  => POD_CIDR
      }
  end

  # ── WORKER nodes ────────────────────────────────────────────────────────────
  (1..NUM_WORKERS).each do |i|
    config.vm.define "worker#{i}" do |worker|
      worker.vm.hostname = "worker#{i}"
      worker_ip = "#{WORKER_IP_BASE}#{WORKER_IP_START + i - 1}"
      worker.vm.network "private_network", ip: worker_ip

      worker.vm.provider "virtualbox" do |vb|
        vb.name   = "k8s-worker#{i}"
        vb.cpus   = 1
        vb.memory = 1024
        vb.customize ["modifyvm", :id, "--natdnshostresolver1", "on"]
      end

      # Workers provision AFTER master (join.sh is generated by master.sh)
      worker.vm.provision "shell", path: "scripts/worker.sh"
    end
  end

end
