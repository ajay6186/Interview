# Terraform local files
.terraform/
.terraform.lock.hcl

# State files — NEVER commit these (contain secrets)
*.tfstate
*.tfstate.backup

# Variable files that may contain secrets
*.tfvars.local
secrets.tfvars
*secret*

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
