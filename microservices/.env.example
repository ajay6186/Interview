# Copy to .env and fill in real values — NEVER commit .env to git

# ── Databases ──────────────────────────────────────────────────────────────
USER_DB_PASSWORD=change_me_user_db
AUTH_DB_PASSWORD=change_me_auth_db
ORDER_DB_PASSWORD=change_me_order_db
PAYMENT_DB_PASSWORD=change_me_payment_db

# ── JWT (generate: openssl rand -hex 64) ──────────────────────────────────
JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# ── RabbitMQ + Redis ───────────────────────────────────────────────────────
RABBITMQ_PASSWORD=change_me_rabbit
REDIS_PASSWORD=change_me_redis

# ── Payment Gateway Selection ──────────────────────────────────────────────
# Set to "stripe" or "razorpay" — only matching keys are required
PAYMENT_GATEWAY=stripe

# ── Stripe (stripe.com → Developers → API keys) ───────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Razorpay (dashboard.razorpay.com → Settings → API Keys) ──────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=change_me_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=change_me_razorpay_webhook_secret

# ── Paytm (business.paytm.com → Developer → API Details) ─────────────────
PAYTM_MERCHANT_ID=YOUR_MID_HERE
PAYTM_MERCHANT_KEY=change_me_paytm_key
PAYTM_WEBSITE=WEBSTAGING               # use DEFAULT for production
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_CHANNEL_ID=WEB
PAYTM_CALLBACK_URL=https://yourdomain.com/api/payments/webhook
PAYTM_BASE_URL=https://securegw-stage.paytm.in  # remove -stage for production

# ── AES-256 key (generate: openssl rand -hex 32) ──────────────────────────
ENCRYPTION_KEY=change_me_64_hex_chars_here_000000000000000000000000000000

# ── SMTP (SendGrid, SES, Mailgun, etc.) ───────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxx
FROM_EMAIL=no-reply@example.com
