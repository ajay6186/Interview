// Exercise 5.2 — Docker CI/CD Pipeline

pipeline {
    agent any

    environment {
        IMAGE_NAME = 'myorg/myapp'
        DEPLOY_HOST = 'deploy@prod.example.com'
    }

    stages {
        stage('Build') {
            steps {
                script {
                    // TODO: Capture short git SHA and store as env.GIT_SHA
                    env.GIT_SHA = sh(script: ???, returnStdout: true).trim()
                    echo "Building ${IMAGE_NAME}:${env.GIT_SHA}"
                    sh "docker build -t ${IMAGE_NAME}:${env.GIT_SHA} -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Test') {
            steps {
                // TODO: Run tests inside the built container
                // Command: docker run --rm <image>:<tag> npm test
                sh "docker run --rm ${IMAGE_NAME}:${env.GIT_SHA} ???"
            }
        }

        stage('Push') {
            // TODO: Only push on the main branch
            when { branch ??? }
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds',
                    usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh 'docker login -u $DOCKER_USER -p $DOCKER_PASS'
                    sh "docker push ${IMAGE_NAME}:${env.GIT_SHA}"
                    sh "docker push ${IMAGE_NAME}:latest"
                }
            }
        }

        stage('Deploy') {
            // TODO: Only deploy on the main branch
            when { branch ??? }
            steps {
                // TODO: SSH to deploy host, pull new image, restart the container
                withCredentials([sshUserPrivateKey(credentialsId: 'deploy-ssh-key',
                    keyFileVariable: 'SSH_KEY')]) {
                    sh """
                        ssh -i $SSH_KEY -o StrictHostKeyChecking=no ${DEPLOY_HOST} \\
                          "docker pull ${IMAGE_NAME}:${env.GIT_SHA} && \\
                           docker stop myapp || true && \\
                           docker run -d --name myapp --rm -p 3000:3000 ${IMAGE_NAME}:${env.GIT_SHA}"
                    """
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${IMAGE_NAME}:${env.GIT_SHA} || true"
        }
    }
}
