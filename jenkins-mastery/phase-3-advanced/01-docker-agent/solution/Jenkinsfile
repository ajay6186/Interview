pipeline {
    agent none

    stages {
        stage('Node Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                }
            }
            steps {
                sh 'node --version'
                sh 'npm --version'
                sh 'echo "Installing deps and building..."'
            }
        }

        stage('Python Test') {
            agent {
                docker {
                    image 'python:3.11-slim'
                    args  '-v /tmp/pip-cache:/root/.cache/pip'
                }
            }
            steps {
                sh 'python --version'
                sh 'pip install pytest --quiet'
                sh 'echo "Running Python tests..."'
            }
        }

        stage('Custom Image') {
            agent {
                dockerfile true
            }
            steps {
                sh 'echo "Running in custom container"'
            }
        }
    }
}
