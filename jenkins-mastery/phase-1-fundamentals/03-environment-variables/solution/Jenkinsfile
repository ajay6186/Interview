pipeline {
    agent any

    environment {
        APP_NAME    = 'myapp'
        APP_VERSION = '1.0.0'
    }

    stages {
        stage('Print Info') {
            steps {
                echo "App: ${APP_NAME}  Version: ${APP_VERSION}"
                echo "Build number: ${env.BUILD_NUMBER}"
                echo "Workspace: ${env.WORKSPACE}"
            }
        }

        stage('Override Env') {
            environment {
                APP_VERSION = '2.0.0-SNAPSHOT'
            }
            steps {
                echo "Stage version: ${APP_VERSION}"
            }
        }

        stage('Back to Original') {
            steps {
                echo "Pipeline version: ${APP_VERSION}"
            }
        }
    }
}
