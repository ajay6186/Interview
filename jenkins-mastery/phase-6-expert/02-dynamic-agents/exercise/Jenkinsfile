kind: Pod
spec:
  containers:
  - name: ???
    image: ???
    command: [cat]
    tty: true
  - name: ???
    image: ???
    securityContext:
      privileged: ???
'''
        }
    }

    stages {
        stage('Node Build') {
            steps {
                // TODO: Run steps inside the "node" container
                container(???) {
                    sh 'node --version'
                    sh 'npm --version'
                    sh 'echo "Installing and building..."'
                }
            }
        }

        stage('Docker Build') {
            steps {
                // TODO: Run steps inside the "docker" container
                container(???) {
                    sh 'docker version'
                    sh 'docker build -t myapp:latest . || echo "No Dockerfile — skipping"'
                }
            }
        }
    }
}
