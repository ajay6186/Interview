// Exercise 6.2 — Dynamic Kubernetes Agents

pipeline {
    // TODO: Define a Kubernetes agent with a pod containing two containers:
    // Container 1: name=node,   image=node:18-alpine,  command=cat, tty=true
    // Container 2: name=docker, image=docker:24-dind, privileged=true
    agent {
        kubernetes {
            yaml '''
